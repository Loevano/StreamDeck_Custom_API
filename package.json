{
  "name": "streamdeck-custom-api",
  "version": "0.1.0",
  "description": "Dynamic Stream Deck plugin driven by an external Custom API layout/state endpoint.",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist release",
    "build:ts": "tsc -p tsconfig.json",
    "package": "node scripts/package-plugin.mjs",
    "build": "npm run clean && npm run build:ts && npm run package",
    "release": "npm run build",
    "api:map": "node scripts/generate-api-map.mjs",
    "dev": "tsx watch src/main.ts -- --dev",
    "start": "node dist/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
